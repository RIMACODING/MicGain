<Window x:Class="MicGain.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MicGain.App.Converters"
        Title="MicGain" Height="440" Width="560" MinHeight="320" MinWidth="440">
    <Window.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <Style x:Key="StateMessageStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="24" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top">
            <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="12,4" VerticalAlignment="Center" />
            <TextBlock Text="Microphone gain (Equalizer APO)" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Non-blocking error/status line (issue #4: IO failures must not crash or block). -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="DarkRed"
                   TextWrapping="Wrap" Margin="0,8,0,0" />

        <Grid Margin="0,12,0,0">
            <TextBlock Text="Loading devices…">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StateMessageStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Loading">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="Equalizer APO was not found on this machine.&#10;Install it, then click Refresh.">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StateMessageStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="ApoNotInstalled">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="No capture devices (microphones) were detected.">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StateMessageStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="NoCaptureDevices">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="Could not load devices — details below.">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StateMessageStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Error">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Ready">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" FontWeight="SemiBold"
                                                   Text="{Binding GainDb, StringFormat='{}{0:0.##} dB'}" />
                                        <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding EndpointGuid}" FontSize="11" Foreground="Gray" />
                                    <Slider Minimum="{Binding MinimumDb}"
                                            Maximum="{Binding MaximumDb}"
                                            Value="{Binding GainDb, Mode=TwoWay}"
                                            IsEnabled="{Binding IsApoEnabled}"
                                            SmallChange="0.5" LargeChange="3"
                                            TickFrequency="5" TickPlacement="BottomRight"
                                            Margin="0,4,0,0" />
                                    <TextBlock Text="Equalizer APO is not enabled on this device — gain control is disabled."
                                               FontSize="11" Foreground="DarkOrange"
                                               Visibility="{Binding IsApoEnabled, Converter={StaticResource InverseBoolToVisibility}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
