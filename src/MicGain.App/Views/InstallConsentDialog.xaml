<Window x:Class="MicGain.App.Views.InstallConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicGain — Install Equalizer APO"
        SizeToContent="Height" Width="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="16">
        <TextBlock Text="{Binding ConsentMessage}" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Install Equalizer APO" Command="{Binding AcceptCommand}"
                    Padding="12,6" Margin="0,0,8,0" />
            <Button Content="No thanks" Command="{Binding DeclineCommand}"
                    Padding="12,6" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
